# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=diadiemyeuthich
DB_USER=postgres
DB_PASS=your_db_password_here

# JWT – dùng chuỗi ngẫu nhiên dài ít nhất 32 ký tự
# Tạo nhanh: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_string_min_32_chars

# Server
PORT=3001

# Origin cho phép gọi API (domain frontend của bạn)
# Dùng * để cho phép tất cả (không an toàn cho production)
ALLOWED_ORIGIN=https://yourdomain.com
